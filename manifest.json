{
  "manifest_version": 3,
  "name": "Prompt Saver",
  "version": "2.0.0",
  "description": "Save, organize, and manage your AI prompts",
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "clipboardWrite", "scripting"],
  "host_permissions": ["https://m365.cloud.microsoft/*"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}